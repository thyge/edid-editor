{
  "name": "edidts",
  "version": "1.0.0",
  "description": "TypeScript library for decoding and encoding EDID, CEA-861, and DisplayID",
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^4.1.7"
  },
  "keywords": [
    "typescript",
    "edid",
    "display",
    "monitor",
    "cea-861",
    "displayid"
  ],
  "license": "MIT"
}
